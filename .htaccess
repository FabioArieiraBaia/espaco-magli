<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Prevents 500 error on some strict shared hosts
  Options -MultiViews
  
  RewriteBase /
  
  # API requests go to the api subfolder
  RewriteCond %{REQUEST_URI} ^/api [NC]
  RewriteRule ^ - [L]

  # Existing files/directories are served directly
  # HostGator specific robust checks
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
  RewriteRule ^ - [L]
  
  # Everything else goes to index.html for React Router
  RewriteRule ^ index.html [QSA,L]
</IfModule>